# Sparsh Hermes Agent — Health Layer environment variables.
# Copy this to `.env` (gitignored) and fill in real values.
# On the VPS, place `.env` at the repo root or wherever your deploy script expects it.

# === Deploy target (read by scripts/deploy.sh) ===
# Your VPS SSH host. Keep the real value in .env (gitignored), not here.
VPS_HOST=hermes@your-vps-ip
# VPS_SSH_KEY=$HOME/.ssh/your_ssh_key
# VPS_REPO_PATH=/home/hermes/sparsh-hermes-agent

# === Required for Phase 1 ===

# USDA FoodData Central API key — free, signup at https://fdc.nal.usda.gov/api-key-signup.html
# Used by food-tracker-mcp for nutrient lookups
USDA_API_KEY=

# === Optional / conditional ===

# OpenAI API key — only needed if:
#   (a) Codex OAuth image-forwarding test (Phase 2) fails — then we route vision through API
#   (b) You decide to use Whisper API instead of local faster-whisper (Phase 2)
# OPENAI_API_KEY=

# === Reference values (set by Hermes install, not by this repo) ===
# These are documented here for reference but are owned by the Hermes config, not us.
# HERMES_HOME=/home/hermes/.hermes
# VAULT_PATH=/home/hermes/vault
# TELEGRAM_BOT_TOKEN=...        # in ~/.hermes/.env, do not duplicate

# === Phase 3 (wearable bridge) — to be filled when HAE is purchased + configured ===

# Bearer token your HAE iOS app uses to authenticate POSTs to the Hermes ingest endpoint.
# Generate any sufficiently-random string. Used by both HAE config and the ingest script.
# HAE_INGEST_TOKEN=

# Port the HAE ingest endpoint listens on (FastAPI, behind nginx/Caddy with TLS).
# HAE_INGEST_PORT=8443
